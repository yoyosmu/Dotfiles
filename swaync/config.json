{
    "positionX": "right",
    "positionY": "top",
    "layer": "overlay",
    "control-center-layer": "top",
    "layer-shell": true,
    "cssPriority": "user",
    "control-center-width": 350,
    "control-center-margin-top": 8,
    "control-center-margin-bottom": 8,
    "control-center-margin-right": 0,
    "control-center-margin-left": 8,
    "notification-2fa-action": true,
    "notification-inline-replies": true,
    "notification-window-width": 350,
    "notification-icon-size": 60,
    "notification-body-image-height":  180,
    "notification-body-image-width": 180,
    "timeout": 12,
    "timeout-low": 6,
    "timeout-critical": 1,
    "fit-to-screen": true,
    "keyboard-shortcuts": true,
    "image-visibility": "when available",
    "transition-time": 200,
    "hide-on-clear": false,
    "hide-on-action": true,
    "script-fail-notify": true,
    "widgets": [
        "title",
        "dnd",
        "notifications",
        "buttons-grid",
        "mpris",
        "volume"
        ],
    "notifications-widget": {
        "visible": true
        }, 
    "widget-config": {
        "title": {
            "text": "Notification Center",
            "clear-all-button": true,
            "button-text": "󰆴"
        },
        "dnd": {
            "text": "Do Not Disturb"
        },
        "label": {
            "max-lines":1,
            "text": "Notification Center!"
        },
        "mpris": {
            "image-size": 80,
            "image-radius": 0
        },
        "volume": {
            "label": " "
        },
        "buttons-grid": {
            "actions": [
                {
                    "label": " ",
                    "active": true,
                    "command": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
                    "type": "toggle"
                },
                {
                    "label": "",
                    "command": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
                    "type": "toggle",
                    "active": true
                },
                {
                    "label": "",
                    "command": "bash -c 'STATE=$(bluetoothctl show | grep \"Powered\" | awk \"{print $2}\"); if [ \"$STATE\" = \"yes\" ]; then bluetoothctl power off; else bluetoothctl power on; fi'",
                    "type": "toggle",
                    "active": true
                },
                {
                    "label": "",
                    "type": "toggle",
                    "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && hyprshade on greyscale || hyprshade off'",
                    "update-command": "sh -c '[[ $(hyprshade current) == \"greyscale\" ]] && echo true || echo false'"
                },
                {
                    "label": "󰕪",
                    "command": "wlogout"
                }
            ]
        }
    }
}
