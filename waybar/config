{
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    "output": "eDP-1",
    "layer": "top",
    "position": "top",
    "height": 24,
    "gtk-layer-shell": true,
    //"spacing": 4,
    "modules-left": ["hyprland/workspaces"],
    "modules-right": ["pulseaudio", "network", "backlight", "battery", "tray", "custom/notification", "custom/calender", "custom/weather", "clock", "group/group-power"],
    "modules-center": [],
    "tray": {
        "spacing": 10
    },

    "hyprland/workspaces": {
        "on-scroll-up": "hyprctl dispatch workspace r+1",
        "on-scroll-down": "hyprctl dispatch workspace r-1",

     "persistent-workspaces": {
         "*": [ 1,2,3 ]
     }
    },

    "clock": {
       "format": "{:%e %b у∞§Г %I:%M<small>%p</small>}",
       "format-alt": "{:L%I:%M<small>%p</small>}",
       "tooltip": false
    },

    "custom/weather": {
        "format": "{}¬∞c",
        "tooltip": true,
        "exec": "wttrbar --date-format \"%d.%m.%Y\" -l en",
        "return-type": "json"
    },

    "custom/calender": {
       "format": "пБ£ пСХ ",
       "on-click": "eww open --toggle date",
       "tooltip": false
    },

    "group/group-power": {
        "orientation": "inherit",
             "drawer": {
                "transition-duration": 500,
                "children-class": "not-poweroff",
                "transition-left-to-right": false,
    },
    "modules": [
          "custom/poweroff", 
          "custom/reboot",
        ]
    },

    "custom/reboot": {
       "format": "пГҐ ",
       "tooltip": false,
       "on-click": "systemctl reboot"
    },

    "custom/poweroff": {
       "format": "пАС ",
       "on-click": "systemctl poweroff",
       "tooltip": false
    },

    "custom/notification": {
      "tooltip": false,
      "format": "{icon}",
      "format-icons": {
        "notification": "оЃЪ ",
        "none": "пТЪ ",
        "dnd-notification": "о∞Й ",
        "dnd-none": "пСЄ "
      },
      "return-type": "json",
      "exec-if": "which swaync-client",
      "exec": "swaync-client -swb",
      "on-click": "sleep 0.1 && swaync-client -t -sw",
      "escape": true
     },

    "backlight": {
        "scroll-step": 5,
        "format": "{icon} {percent}%",
        "format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"],
        "format-alt": "{icon}",
        "tooltip": false
    },

    "battery": {
        "states": {
            "warning": 20,
            "critical": 10
        },
        "format": "{icon} {capacity}%",
        "format-alt": "{icon}",
        "format-charging": "оЇ° {capacity}%",
        "format-icons": ["пЙД ", "пЙГ ", "пЙВ ", "пЙБ ", "пЙА "],
        "tooltip": false
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) {icon}",
        "format-ethernet": "ољД  {ifname}",
        "format-icons": ["ољД ", "у∞§• ", "у∞§Ґ ", "у∞§Я ", "у∞§ѓ "],
        "tooltip-format": "ољД {ifname} via {gwaddr}",
        "format-linked": "ољД {ifname} (No IP)",
        "format-disconnected": "Disconnected у∞Ц™ {ifname}",
        "format-alt": "ољД {ifname}: {ipaddr}/{cidr}"
    },

    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon}{volume}%",
        "format-bluetooth": "пКФ {icon}{volume}%",
        "format-bluetooth-muted": "пКФ ої® ",
        "format-muted": "ої® {volume}%",
        "format-icons": {
            "default": ["пА¶", "пАІ", "пА® "],
    },
    "format-alt": "{icon}",
   "tooltip": false
   },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null"
    }
}
