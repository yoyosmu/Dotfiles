[
    {
        "output": "eDP-1",
        "layer": "top",
        "position": "top",
        "height": 24,
        "gtk-layer-shell": true,
        "modules-left": ["hyprland/workspaces"],
        "modules-right": ["pulseaudio", "network", "bluetooth", "backlight", "battery", "tray", "custom/notification", "custom/weather", "clock", "group/group-power"],
        "modules-center": [],
        "tray": {
            "spacing": 10
        },
        "hyprland/workspaces": {
            "on-scroll-up": "hyprctl dispatch workspace r+1",
            "on-scroll-down": "hyprctl dispatch workspace r-1",
            "persistent-workspaces": {
                "*": [ 1,2,3 ]
            }
        },
        "clock": {
           "format": "{:%e %b≤░νΔ%I:%M<small>%p</small>}",
           "format-alt": "{:L%I:%M<small>%p</small>}",
           "tooltip-format": "<tt><small>{calendar}</small></tt>",
           		"calendar": {
           			"format": {
           				"months": "<span color='#ffffff'><b>{}</b></span>",
           				"weekdays": "<span color='#5a8d50'><b>{}</b></span>",
           				"today": "<span color='#5a8d50'><b><u>{}</u></b></span>"
           			}
           		}
        },
        "custom/weather": {
            "format": "{}┬░c",
            "tooltip": true,
            "exec": "wttrbar --nerd",
            "on-click": "~/.config/ignis/mutex-toggle.sh weather",
            "interval": 1800,
            "return-type": "json"
        },
        "group/group-power": {
            "orientation": "inherit",
            "drawer": {
                "transition-duration": 500,
                "children-class": "not-poweroff",
                "transition-left-to-right": false
            },
            "modules": [
              "custom/poweroff", 
              "custom/reboot"
            ]
        },
        "custom/reboot": {
           "format": "ΎΔλ ",
           "tooltip": false,
           "on-click": "systemctl reboot"
        },
        "custom/poweroff": {
           "format": "ΎΑΣ ",
           "on-click": "systemctl poweroff",
           "tooltip": false
        },
        "custom/notification": {
          "tooltip": false,
          "format": "{icon}",
          "format-icons": {
            "notification": "Όχγ ",
            "none": "ΎΤγ ",
            "dnd-notification": "Ό░Κ ",
            "dnd-none": "ΎΣ╕ "
          },
          "return-type": "json",
          "exec-if": "which swaync-client",
          "exec": "swaync-client -swb",
          "on-click": "swaync-client -t -sw",
          "escape": true
         },
        "backlight": {
            "scroll-step": 5,
            "format": "{icon} {percent}%",
            "format-icons": ["ΌΟΞ ", "ΌΠΦ ", "ΌΠΥ ", "ΌΠΤ ", "ΌΠΣ ", "ΌΠΡ ", "ΌΠΠ ", "ΌΠΟ ", "ΌΠΞ ", "ΌΠΝ ", "ΌΠΛ ", "ΌΠΙ ", "ΌΟδ "],
            "format-alt": "{icon}",
            "tooltip": false
        },
        "battery": {
            "states": {
                "warning": 20,
                "critical": 10
            },
            "format": "{icon} {capacity}%",
            "format-alt": "{icon}",
            "format-charging": "{icon} {capacity}%",
            "format-icons": ["≤░ΓΟ ", "≤░Β║ ", "≤░Β╝ ", "≤░Β╜ ", "≤░Β╛ ", "≤░ΓΑ ", "≤░ΓΒ ", "≤░ΓΓ ", "≤░Β╣ "],
            "tooltip-format": "{timeTo}"
        },
        "network": {
            "format-wifi": "{icon}",
            "format-ethernet": "Ό╜Ε ",
            "format-icons": ["Ό╜Ε ", "≤░νρ ", "≤░νξ ", "≤░νλ ", "≤░νθ ", "≤░ντ "],
            "tooltip-format": "{ifname}\nDown Speed: {bandwidthDownBits}\nUp Speed: {bandwidthUpBits}",
            "tooltip-format-wifi": "{essid} ({signalStrength}%)",
            "tooltip-format-ethernet": "{ifname}\nDown Speed: {bandwidthDownBits}\nUp Speed: {bandwidthUpBits}",
            "format-disconnected": "≤░νχ ",
            "on-click": "/home/yoyomu/.config/ignis/mutex-toggle.sh wifi"
        },
        "bluetooth": {
            "format": "ΎΛΦ",
            "format-disabled": "≤░Γ▓",
            "format-connected": "≤░Γ▒ {num_connections}",
            "tooltip-format": "Devices connected: {num_connections}",
            "on-click": "/home/yoyomu/.config/ignis/mutex-toggle.sh bluetooth-island"
        },
        "pulseaudio": {
            "scroll-step": 5,
            "format": "{icon} {volume}%",
            "format-bluetooth": "ΎΛΦ{icon} {volume}%",
            "format-bluetooth-muted": "ΎΛΦΌ╗ρ ",
            "format-muted": "Ό╗ρ ",
            "format-icons": {
                "headphone": "ΎΑξ  ",
                "headset":  "≤░ΜΟ ",
                "default": ["ΎΑο ", "ΎΑπ ", "ΎΑρ  "]
            },
            "format-alt": "{icon}",
            "tooltip": false
        }
    },
    {
      "output": "eDP-1",
      "position": "bottom",
      "layer": "top",
      "height": 24,
      "gtk-layer-shell": true,
      "modules-center": ["custom/cava"],
      "modules-left": ["custom/search", "custom/launcher", "custom/launcher2", "custom/launcher3", "wlr/taskbar", "keyboard/state"],
      "modules-right": ["group/system", "idle_inhibitor", "keyboard-state"],
      "keyboard-state": {
        "capslock": true,
        "format": "{icon}",
        "format-icons": {
          "locked": "ΎΑμ",
          "unlocked": "ΎΣΨ"
        }
      },
      "custom/cava": {
          "exec": "~/.config/waybar/cava.sh",
          "format": "{}",
          "on-click": "~/.config/ignis/mutex-toggle.sh eq",
          "tooltip": false
      },
      "wlr/taskbar": {
          "format": "{icon} {title:.18}",
          "icon-size": 16,
          "on-click-right": "close",
          "tooltip-format": "{title}",
          "ignore-list": [],
          "tooltip": false,
          "on-click": "activate"
       },
        "idle_inhibitor": {
            "format": "{icon}",
            "format-icons": {
                "activated": "≤░Τ│ ",
                "deactivated": "≤░Τ▓ "
            },
            "tooltip": false
        },
        "group/system": {
            "orientation": "inherit",
            "click-to-reveal": true,
                 "drawer": {
                    "transition-duration": 500,
                    "transition-left-to-right": false
        },
        "modules": [
              "custom/draweropener",
              "cpu",
              "memory", 
              "disk"
            ]
        },
        "custom/search": {
           "format": "ΎΞβ ",
           "on-click": "rofi -show drun",
           "tooltip": false
        },
       "custom/draweropener": {
           "tooltip": false,
           "format": "ΎΒι ΎΡμ "
       },
       "cpu": {
           "interval": 5,
           "format": "ΎΜδ  {usage}%",
           "max-length": 10
       },
       "disk": {
           "interval": 30,
           "format": "≤░ΜΛ {percentage_used}%",
           "path": "/",
           "tooltip": true,
           "unit": "GB",
           "tooltip-format":  "Available {free} of {total}"
       },
       "memory": {
           "interval": 10,
           "format": "Ό╜Ν   {percentage}%",
           "max-length": 10,
           "tooltip": true,
           "tooltip-format": "RAM - {used:0.1f}GiB used"
       },
      "custom/launcher": {
        "on-click": "org.vinegarhq.Sober",
        "format": "ΎΤ┐ ",
        "tooltip": false,
        "return-type": "json"
      },
      "custom/launcher2": {
        "on-click": "brave",
        "format": "ΎΗι ",
        "tooltip": false,
        "return-type": "json"
      },
      "custom/launcher3": {
        "on-click": "vesktop",
        "format": "ΎΘ┐ ",
        "tooltip": false,
        "return-type": "json"
      }
    }
]
